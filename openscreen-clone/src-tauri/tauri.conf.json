{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-nightly-schema/main/tauri.schema.json",
  "productName": "BloomScreen",
  "version": "1.0.0",
  "identifier": "com.bloommedia.bloomscreen",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build-vite"
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          { "path": "$APPDATA/**" },
          { "path": "$HOME/**" },
          { "path": "$RESOURCE/**" }
        ],
        "deny": []
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BloomScreen",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            { "path": "$APPDATA/**" },
            { "path": "$HOME/**" },
            { "path": "$RESOURCE/**" }
          ]
        }
      }
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
